{
  "name": "react-render-cost",
  "version": "0.1.0",
  "description": "Rank React components by average render cost from Profiler data — find your slowest components, gate them in CI, and diff two runs.",
  "keywords": [
    "react",
    "profiler",
    "performance",
    "render",
    "cli",
    "performance-budget",
    "react-devtools",
    "benchmark",
    "actualDuration",
    "regression"
  ],
  "author": "kea0811",
  "license": "MIT",
  "homepage": "https://react-render-cost.vercel.app",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kea0811/react-render-cost.git"
  },
  "bugs": {
    "url": "https://github.com/kea0811/react-render-cost/issues"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "bin": {
    "react-render-cost": "./dist/bin.js",
    "rrc": "./dist/bin.js"
  },
  "files": [
    "dist",
    "README.md",
    "SKILL.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "tsup --watch",
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "commander": "^12.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.7.5",
    "@vitest/coverage-v8": "^2.1.2",
    "tsup": "^8.3.0",
    "typescript": "^5.6.2",
    "vitest": "^2.1.2"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "pnpm@10.28.1",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
